# Formspree endpoints for the two lead forms on this site.
#
# Setup (5 minutes, no code):
# 1. Go to https://formspree.io and sign up (free tier: 50 submissions/month).
# 2. Create a form called "Admissions" -> copy its endpoint, e.g.
#    https://formspree.io/f/abcdwxyz
# 3. Create a second form called "Contact" -> copy its endpoint.
# 4. Paste both below, then rebuild/redeploy the site.
# 5. In Formspree's dashboard, add the email address(es) that should
#    receive notifications for each form (e.g. admissions@yourinstitute.in).
#
# Until these are set, both forms fall back to a mocked "success" response
# so you can still demo the site end-to-end.

VITE_FORMSPREE_CONTACT_ENDPOINT=your_contact_formspree_endpoint_here
VITE_FORMSPREE_ADMISSION_ENDPOINT=your_admission_formspree_endpoint_here

# VITE_FORMSPREE_ADMISSION_ENDPOINT=https://formspree.io/f/mnjkrejb
# VITE_FORMSPREE_CONTACT_ENDPOINT=https://formspree.io/f/xgojqgzg  # your contact form ID here

# Optional: only needed if/when you build a real backend API later
# (see coursesService.js for the fetch-with-fallback pattern that uses this).
VITE_API_BASE_URL=
